["check"] = "event",
["custom"] = "function(s, e, ...)\n    local spell = C_Spell.GetSpellPowerCost(121253)\n    if spell[1] then\n        if spell[1].cost == 0 then\n            if not s[\"\"] then\n                local state = {\n                    progressType = \"timed\",\n                    duration = 12,\n                    expirationTime = 12+GetTime(),\n                    autoHide = true,\n                }\n                s:Update(\"\", state)\n            end            \n        else\n            s:RemoveAll()\n        end\n    end\nend\n\n\n\n",
